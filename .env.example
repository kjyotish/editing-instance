VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase Edge Function secrets. Set these with:
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=... SENDGRID_API_KEY=... EMAIL_TO=...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_TO=you@example.com
EMAIL_FROM=verified-sender@example.com

# Alternative to SendGrid:
# GMAIL_SMTP_USER=you@gmail.com
# GMAIL_SMTP_PASSWORD=your-gmail-app-password
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=465
